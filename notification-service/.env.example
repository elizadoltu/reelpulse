# ── Server ──────────────────────────────────────────────────────────────────
PORT=3002
NODE_ENV=development

# ── GCP Project ─────────────────────────────────────────────────────────────
# Found at: console.cloud.google.com → select project → Project ID in header
GCP_PROJECT_ID=your-project-id

# ── Pub/Sub ─────────────────────────────────────────────────────────────────
# Found at: console.cloud.google.com → Pub/Sub → Subscriptions
PUBSUB_SUBSCRIPTION_REVIEW_PROCESSED=review-processed-sub

# ── gRPC (Service A) ─────────────────────────────────────────────────────────
# URL of Service A for gRPC movie title lookups
SERVICE_A_GRPC_URL=localhost:50051

# ── Local dev mock ───────────────────────────────────────────────────────────
MOCK_PUBSUB=true
