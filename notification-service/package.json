{
  "name": "@reelpulse/notification-service",
  "version": "1.0.0",
  "description": "Notification Service - WebSocket server with Pub/Sub pull subscription for real-time review status updates",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.0",
    "@fastify/websocket": "^10.0.0",
    "@google-cloud/pubsub": "^4.4.0",
    "fastify": "^4.26.0",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.7.0",
    "vitest": "^1.4.0",
    "ws": "^8.20.0",
    "ts-proto": "^2.11.6"
  }
}
