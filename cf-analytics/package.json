{
  "name": "@reelpulse/cf-analytics",
  "version": "1.0.0",
  "description": "Cloud Function #1 - Analytics Processor: consumes MovieViewedEvent from Pub/Sub and writes to BigQuery",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "start": "npx @google-cloud/functions-framework --target=cf-analytics --signature-type=cloudevent"
  },
  "dependencies": {
    "@google-cloud/bigquery": "^7.8.0",
    "@google-cloud/functions-framework": "^3.3.0",
    "@google-cloud/pubsub": "^4.11.0",
    "@google-cloud/vertexai": "^1.12.0",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
