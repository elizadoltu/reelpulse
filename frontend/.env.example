# ── API URLs ─────────────────────────────────────────────────────────────────
# Vite exposes only variables prefixed with VITE_ to the browser bundle
# Local development
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3002

# Production (set these as GitHub Secrets: VITE_API_URL, VITE_WS_URL)
# VITE_API_URL=https://service-a-xxxx-ew.a.run.app
# VITE_WS_URL=wss://notification-service-xxxx-ew.a.run.app
# Found at: console.cloud.google.com → Cloud Run → your service → URL
