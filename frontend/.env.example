# ── Dev proxy (no VITE_ prefix — only visible to vite.config.ts, never bundled) ──
# Requests to /api/* are forwarded here by the Vite dev server, avoiding CORS.
# Defaults to http://localhost:3001 if omitted.
SERVICE_A_URL=https://service-a-xxxx-ew.a.run.app

# ── Browser-visible API URL ────────────────────────────────────────────────────
# Leave empty in dev (Vite proxy handles it).
# Set to the full Cloud Run URL for production builds.
VITE_API_URL=
VITE_WS_URL=ws://localhost:3002

# Production values (set as GitHub Secrets / Cloud Run env vars):
# VITE_API_URL=https://service-a-xxxx-ew.a.run.app
# VITE_WS_URL=wss://notification-service-xxxx-ew.a.run.app
