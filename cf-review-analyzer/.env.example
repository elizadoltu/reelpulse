# ── GCP Project ─────────────────────────────────────────────────────────────
# Found at: console.cloud.google.com → select project → Project ID in header
GCP_PROJECT_ID=your-project-id

# ── Gemini AI ────────────────────────────────────────────────────────────────
# Found at: aistudio.google.com → Get API key
GEMINI_API_KEY=your-gemini-api-key

# ── Pub/Sub ──────────────────────────────────────────────────────────────────
# Found at: console.cloud.google.com → Pub/Sub → Topics
PUBSUB_TOPIC_REVIEW_PROCESSED=review-processed

# ── Firestore ────────────────────────────────────────────────────────────────
# Found at: console.cloud.google.com → Firestore
# No extra config needed — uses GCP_PROJECT_ID + Application Default Credentials

# ── Local dev ────────────────────────────────────────────────────────────────
# Use Functions Framework to run locally:
#   npx @google-cloud/functions-framework --target=reviewAnalyzer
# Set GOOGLE_APPLICATION_CREDENTIALS to a service account key JSON for local auth:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json
