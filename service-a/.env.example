# ── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# In GCP: store in Secret Manager as JWT_SECRET, referenced via --set-secrets in Cloud Run
JWT_SECRET=your-secret-here

# ── GCP Project ─────────────────────────────────────────────────────────────
# Found at: console.cloud.google.com → select project → Project ID in header
GCP_PROJECT_ID=your-project-id

# ── Pub/Sub ─────────────────────────────────────────────────────────────────
# Found at: console.cloud.google.com → Pub/Sub → Topics
PUBSUB_PROJECT_ID=your-project-id
PUBSUB_TOPIC_MOVIE_EVENTS=movie-events
PUBSUB_TOPIC_REVIEW_SUBMITTED=review-submitted

# ── Firestore ────────────────────────────────────────────────────────────────
# Found at: console.cloud.google.com → Firestore
# No extra config needed — uses GCP_PROJECT_ID + Application Default Credentials

# ── MongoDB ──────────────────────────────────────────────────────────────────
# Found at: cloud.mongodb.com → Connect → Drivers → Connection string
MONGO_URL=mongodb+srv://user:password@cluster.mongodb.net/reelpulse
# ── Local dev mock (set to true to skip real GCP calls) ─────────────────────
MOCK_PUBSUB=true
MOCK_FIRESTORE=true

APP_CONTAINER_NAME=fastLazyBee-app
APP_HOST_PORT=3042
APP_CONTAINER_PORT=3000
APP_PORT=3000

# for local testing
MONGO_IMAGE=mongo:8
MONGO_CONTAINER_NAME=fastLazyBee-mongo
MONGO_DB_NAME=sample_mflix
MONGO_HOST_PORT=27027
MONGO_CONTAINER_PORT=27017

VOLUME_NAME=fastLazyBee-volume