{
  "name": "fast-lazy-bee",
  "version": "0.0.1",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "dev": "npx tsx watch src/index.ts",
    "format": "npx prettier --write src/**/*.ts .vscode/*.json ./**/*.json",
    "lint": "npx eslint . --fix",
    "typecheck": "npx tsc --noEmit",
    "test": "npm run clean && npx jest",
    "test:run": "npx vitest run",
    "test:integration": "npx vitest run src/test/routes",
    "test:infra": "npx vitest run src/test/utils/test-utils.test.ts",
    "clean": "rimraf dist",
    "build": "npm run clean && npx tsc -p tsconfig.build.json",
    "start": "node dist/src/index.js"
  },
  "keywords": [
    "fastify",
    "typescript",
    "mongodb",
    "restful-api"
  ],
  "author": "Riccardo Mura",
  "license": "MIT",
  "dependencies": {
    "@fastify/autoload": "^6.3.1",
    "@fastify/caching": "^9.0.3",
    "@fastify/cors": "^10.0.0",
    "@fastify/env": "^5.0.3",
    "@fastify/etag": "^6.1.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/mongodb": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.6.1",
    "@fastify/swagger-ui": "^5.2.5",
    "@google-cloud/firestore": "^7.6.0",
    "@google-cloud/pubsub": "^4.4.0",
    "@sinclair/typebox": "^0.34.48",
    "fastify": "^5.7.4",
    "fastify-plugin": "^5.1.0",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@testcontainers/mongodb": "^11.11.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.1",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitest/coverage-v8": "^1.6.0",
    "babel-jest": "^30.2.0",
    "eslint": "^9.39.2",
    "eslint-config-love": "^149.0.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "fastify-tsconfig": "^3.0.0",
    "jest": "^30.2.0",
    "mongodb": "^7.2.0",
    "mongodb-memory-server": "^11.0.1",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "@types/ws": "^8.18.1",
    "tsx": "^4.7.0",
    "vitest": "^1.4.0",
    "ws": "^8.20.0",
    "ts-proto": "^2.11.6"
  }
}
