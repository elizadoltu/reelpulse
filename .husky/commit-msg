#!/bin/sh
# Enforce Conventional Commits format:
# <type>(optional scope): <description>
# Types: feat, fix, chore, docs, style, refactor, test, ci, perf, build

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

PATTERN="^(feat|fix|chore|docs|style|refactor|test|ci|perf|build)(\(.+\))?: .{1,100}$"

if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
  echo ""
  echo "❌ Invalid commit message format."
  echo ""
  echo "   Expected: <type>(scope): <description>"
  echo "   Example:  feat(service-a): add movie view event publisher"
  echo ""
  echo "   Valid types: feat, fix, chore, docs, style, refactor, test, ci, perf, build"
  echo ""
  exit 1
fi
